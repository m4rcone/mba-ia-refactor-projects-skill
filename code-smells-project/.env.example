# Chave usada pelo Flask para assinatura de sessão/cookies
SECRET_KEY=troque-esta-chave

# Caminho do arquivo SQLite
DB_PATH=loja.db

# Modo debug do Flask (1 para ligar, 0 para desligar)
FLASK_DEBUG=0

# Host e porta do servidor
HOST=0.0.0.0
PORT=5000

# Ambiente da aplicação (development, production, ...)
APP_ENV=development
